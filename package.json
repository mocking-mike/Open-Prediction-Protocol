{
  "name": "open-prediction-protocol",
  "version": "0.1.0",
  "description": "Open protocol for AI agents to discover prediction providers, request forecasts, compare trust signals, and pay — all through a single standard.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "spec",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:packages": "pnpm --filter ./packages/create-opp-agent run build",
    "build:all": "pnpm run build && pnpm run build:packages",
    "release:check": "pnpm run typecheck && pnpm test && pnpm run integration && pnpm run build:all",
    "release:pack": "node scripts/pack-release-artifacts.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "conformance:http": "tsx scripts/run-http-conformance.ts",
    "example:weather": "tsx examples/weather-proxy.ts",
    "example:crypto": "tsx examples/crypto-proxy.ts",
    "example:sports": "tsx examples/sports-proxy.ts",
    "example:signed-paid": "tsx examples/signed-paid-weather-proxy.ts",
    "example:aggregation": "tsx examples/aggregation-demo.ts",
    "integration": "tsx examples/integration-test.ts"
  },
  "keywords": [
    "predictions",
    "forecasting",
    "ai-agents",
    "open-protocol",
    "probabilistic",
    "trust",
    "agentic",
    "mcp",
    "a2a"
  ],
  "author": "",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.18.2",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@x402/express": "^2.8.0",
    "@x402/fetch": "^2.8.0",
    "ajv": "^8.17.1",
    "bs58": "^6.0.0",
    "express": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
