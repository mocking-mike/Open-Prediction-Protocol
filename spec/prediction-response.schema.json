{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openpredictionprotocol.org/schemas/prediction-response.schema.json",
  "title": "OPP Prediction Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "responseId",
    "requestId",
    "status",
    "createdAt",
    "provider"
  ],
  "properties": {
    "responseId": {
      "type": "string",
      "minLength": 1
    },
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["completed", "failed"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "did": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "forecast": {
      "type": "object",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "domain", "horizon", "generatedAt", "probability"],
          "properties": {
            "type": {
              "const": "binary-probability"
            },
            "domain": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:\\.[a-z0-9]+)+$"
            },
            "horizon": {
              "type": "string",
              "minLength": 1
            },
            "generatedAt": {
              "type": "string",
              "format": "date-time"
            },
            "probability": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "rationale": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "domain", "horizon", "generatedAt", "distribution"],
          "properties": {
            "type": {
              "const": "categorical-distribution"
            },
            "domain": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:\\.[a-z0-9]+)+$"
            },
            "horizon": {
              "type": "string",
              "minLength": 1
            },
            "generatedAt": {
              "type": "string",
              "format": "date-time"
            },
            "distribution": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["label", "probability"],
                "properties": {
                  "label": {
                    "type": "string",
                    "minLength": 1
                  },
                  "probability": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  }
                }
              }
            },
            "rationale": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "domain", "horizon", "generatedAt", "range"],
          "properties": {
            "type": {
              "const": "numeric-range"
            },
            "domain": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:\\.[a-z0-9]+)+$"
            },
            "horizon": {
              "type": "string",
              "minLength": 1
            },
            "generatedAt": {
              "type": "string",
              "format": "date-time"
            },
            "range": {
              "type": "object",
              "additionalProperties": false,
              "required": ["min", "max"],
              "properties": {
                "min": {
                  "type": "number"
                },
                "max": {
                  "type": "number"
                },
                "units": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "rationale": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "nonce": {
          "type": "string",
          "minLength": 1
        },
        "recipientDid": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dependencyChain": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["responseId", "domain"],
            "properties": {
              "responseId": {
                "type": "string",
                "minLength": 1
              },
              "domain": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:\\.[a-z0-9]+)+$"
              }
            }
          }
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "value"],
      "properties": {
        "alg": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": true
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "failed"
          }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["error"],
        "properties": {
          "error": {
            "$ref": "#/properties/error"
          },
          "forecast": false
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "completed"
          }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["forecast"],
        "properties": {
          "forecast": {
            "$ref": "#/properties/forecast"
          },
          "error": false
        }
      }
    }
  ]
}
