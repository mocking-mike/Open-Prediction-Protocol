{
  "name": "create-opp-agent",
  "version": "0.1.0",
  "description": "Minimal scaffolding tool for bootstrapping an OPP provider package.",
  "license": "ISC",
  "type": "module",
  "types": "./dist/index.d.ts",
  "bin": {
    "create-opp-agent": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean"
  },
  "publishConfig": {
    "access": "public"
  }
}
